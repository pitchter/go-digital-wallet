									"const rotate = (pm.environment.get('auto_rotate_idempotency_keys') || 'true') === 'true';",
									"const prefix = pm.environment.get('reverse_idempotency_prefix') || 'reverse';",
									"if (rotate) {",
									"  pm.collectionVariables.set('reverse_idempotency_key', `${prefix}-${Date.now()}`);",
									"}"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 201', function () {",
									"  pm.response.to.have.status(201);",
									"});",
									"const body = pm.response.json();",
									"pm.collectionVariables.set('reversal_transaction_id', body.id);"
								]
							}
						}
