								"exec": [
									"const rotate = (pm.environment.get('auto_rotate_idempotency_keys') || 'true') === 'true';",
									"const prefix = pm.environment.get('topup_idempotency_prefix') || 'topup';",
									"if (rotate) {",
									"  pm.collectionVariables.set('topup_idempotency_key', `${prefix}-${Date.now()}`);",
									"}"
