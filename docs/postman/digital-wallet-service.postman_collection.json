		{
			"name": "Health",
			"item": [
				{
					"name": "Initialize Run + Healthz",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const env = (key, fallback) => pm.environment.get(key) || fallback;",
									"const runId = Date.now().toString();",
									"const suffix = runId.slice(-8);",
									"pm.collectionVariables.set('run_id', runId);",
									"pm.collectionVariables.set('user_a_external_ref', `${env('user_a_external_ref_prefix', 'alice')}-${runId}`);",
									"pm.collectionVariables.set('user_b_external_ref', `${env('user_b_external_ref_prefix', 'bob')}-${runId}`);",
									"pm.collectionVariables.set('user_a_updated_external_ref', `${env('user_a_updated_external_ref_prefix', 'alice-updated')}-${runId}`);",
									"pm.collectionVariables.set('user_a_email', `${env('user_a_email_prefix', 'alice')}.${runId}@${env('email_domain', 'example.com')}`);",
									"pm.collectionVariables.set('user_b_email', `${env('user_b_email_prefix', 'bob')}.${runId}@${env('email_domain', 'example.com')}`);",
									"pm.collectionVariables.set('user_a_phone', `${env('user_a_phone_prefix', '08')}${suffix}`);",
									"pm.collectionVariables.set('user_b_phone', `${env('user_b_phone_prefix', '09')}${suffix}`);",
									"pm.collectionVariables.set('user_a_id', '');",
									"pm.collectionVariables.set('user_b_id', '');",
									"pm.collectionVariables.set('wallet_a_id', '');",
									"pm.collectionVariables.set('wallet_b_id', '');",
									"pm.collectionVariables.set('topup_transaction_id', '');",
									"pm.collectionVariables.set('transfer_transaction_id', '');",
									"pm.collectionVariables.set('reversal_transaction_id', '');",
									"pm.collectionVariables.set('topup_idempotency_key', `${env('topup_idempotency_prefix', 'topup')}-${runId}`);",
									"pm.collectionVariables.set('transfer_idempotency_key', `${env('transfer_idempotency_prefix', 'transfer')}-${runId}`);",
									"pm.collectionVariables.set('reverse_idempotency_key', `${env('reverse_idempotency_prefix', 'reverse')}-${runId}`);"
								]
							}
						},
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('status is 200', function () {",
									"  pm.response.to.have.status(200);",
									"});",
									"const body = pm.response.json();",
									"pm.test('health is ok', function () {",
									"  pm.expect(body.status).to.eql('ok');",
									"});"
								]
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/healthz",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"healthz"
							]
						},
						"description": "Initializes reusable variables for this run, then checks the health endpoint."
					},
					"response": []
				},
